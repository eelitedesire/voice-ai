# ── Production environment for AI Co-Therapist ────────────────────────────
# Copy to .env.production on the server and fill in real values:
#   cp .env.production.example .env.production && nano .env.production
# This file is read by the systemd unit (EnvironmentFile=). NEVER commit the
# filled-in .env.production — it is gitignored.

# ── Required secrets ──────────────────────────────────────────────────────
# Groq API key for the LLM analysis. Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Secret used to encrypt the relationship/therapy vault (.vault/).
# Generate a strong value once and keep it stable:  openssl rand -hex 32
VAULT_SECRET=

# ── Runtime (usually leave as-is; systemd also sets these) ─────────────────
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

# Where the downloaded sherpa-onnx models live (relative to project root).
# MODEL_PATH=models

# ── Optional tuning knobs (safe defaults exist in code) ───────────────────
# Diarization / VAD / ASR thresholds — only set if you need to override.
# LIVE_DIARIZATION=true
# EMBEDDING_MODEL_ID=
# VAD_THRESHOLD=
# VAD_MIN_SILENCE=
# VAD_MIN_SPEECH=
